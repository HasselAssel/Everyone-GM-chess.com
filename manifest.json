{
  "manifest_version": 3,
  "name": "Everyone-GM-chess.com",
  "version": "1.0",
  "description": "Everyone is a Grand Master of Chess in their heart",
  "content_scripts": [
    {
      "matches": ["*://*.chess.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "Everyone-GM-chess.com@hasselassel.github.io"
    }
  },
  "icons": {
    "128": "icon-128.png"
  }
}